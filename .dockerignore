# Optimized .dockerignore for Node.js

# Version control
.git/
.github/
.gitignore

# Dependencies (installed in container)
node_modules/

# Build outputs (built in container)
dist/

db-data/
db

# Environment files
.env*

# Development files
.vscode/
*.log
coverage/
.eslintcache

# OS files
.DS_Store
Thumbs.db

# Documentation
*.md
docs/

# Deployment configs
compose*.yml

# Non-essential configs (keep build configs)
*.config.js
!esbuild.config.js
!eslint.config.js